# ------------------------------------------------------------------------------
# SimuladorÁgil — Environment Variables (Local Development)
# ------------------------------------------------------------------------------
# Copy this file to .env and adjust values as needed:
#   cp .env.example .env
#
# In Docker, these values are injected automatically. For local dev (no Docker),
# the frontend reads VITE_API_URL and the backend reads the SPRING_* variables.
# ------------------------------------------------------------------------------

# --- API / CORS ---------------------------------------------------------------
# Comma-separated list of origins allowed by the backend CORS filter.
# Defaults cover Docker (http://web) and common local dev URLs.
CORS_ALLOWED_ORIGINS=http://localhost,https://simulador-agil.vercel.app,http://web

# Comma-separated list of trusted proxy IPs. Leave empty to ignore X-Forwarded-For.
RATE_LIMIT_TRUSTED_PROXIES=

# --- Redis (used by Docker Compose; ignored by backend test profile) ----------
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# --- Frontend (local Vite dev server only) ------------------------------------
# The production build uses a relative path (/api) and relies on nginx proxying.
VITE_API_URL=http://localhost:8080/api
